{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "summary",
          "risk",
          "category",
          "evidence",
          "constraints",
          "acceptanceCriteria",
          "autoReady"
        ],
        "properties": {
          "title": {"type": "string", "minLength": 5, "maxLength": 100},
          "summary": {"type": "string", "minLength": 10, "maxLength": 1000},
          "risk": {"enum": ["low", "medium", "high"]},
          "category": {
            "enum": [
              "docs",
              "tests",
              "bug",
              "ui",
              "quality",
              "database",
              "auth",
              "dependency",
              "deployment",
              "architecture"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 3}
          },
          "constraints": {"type": "array", "items": {"type": "string"}},
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 3}
          },
          "autoReady": {"type": "boolean"}
        }
      }
    }
  }
}
