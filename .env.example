# Application
APP_ENV=development
APP_NAME=Knowledge Isle
APP_LOCALE=zh-CN
API_PORT=8000
WEB_PORT=5173

# Security - replace every value before deployment
SECRET_KEY=replace-with-at-least-32-random-characters
ADMIN_SETUP_TOKEN=replace-with-a-one-time-setup-token
SESSION_TTL_DAYS=14

# PostgreSQL
POSTGRES_DB=knowledge_isle
POSTGRES_USER=knowledge_isle
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+asyncpg://knowledge_isle:replace-with-a-strong-password@localhost:5432/knowledge_isle

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=knowledge_isle
MINIO_SECRET_KEY=replace-with-a-strong-password
MINIO_BUCKET=knowledge-isle-private
MINIO_SECURE=false
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# AI provider - never commit real credentials
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-5.6-sol
AI_STREAM_MODE=auto
